# Supabase PostgreSQL.
# Para Vercel usa Transaction pooler o Session pooler y agrega pgbouncer=true si tu pooler muestra errores de prepared statements.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true"

NEXTAUTH_SECRET="cambia-este-secreto"
NEXTAUTH_URL="http://localhost:3000"

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

BLOB_READ_WRITE_TOKEN=
